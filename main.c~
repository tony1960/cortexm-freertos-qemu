#define SysTick_Handler xPortSysTickHandler
#define PendSV_Handler xPortPendSVHandler
#define SVC_Handler vPortSVCHandler

#include "FreeRTOS.h"
#include "task.h"

#include "uart.h"

TaskHandle_t worker_handle;

/*
 * Tick hook runs in ISR context
 */

void vApplicationTickHook(void)
{
    BaseType_t higher_woken = pdFALSE;

    vTaskNotifyGiveFromISR(
        worker_handle,
        &higher_woken
    );

    portYIELD_FROM_ISR(higher_woken);
}

void worker_task(void *params)
{
    (void)params;

    while (1) {

        ulTaskNotifyTake(
            pdTRUE,
            portMAX_DELAY
        );

        uart_puts("Worker woke from notification\n");
    }
}

int main(void)
{
    uart_init();

    uart_puts("Starting task notification demo\n");

    xTaskCreate(
        worker_task,
        "Worker",
        256,
        0,
        2,
        &worker_handle
    );

    vTaskStartScheduler();

    while (1) {
    }
}

void *memset(void *s, int c, unsigned int n)
{
    unsigned char *p = s;

    while (n--) {
        *p++ = (unsigned char)c;
    }

    return s;
}

void *memcpy(void *dest, const void *src, unsigned int n)
{
    unsigned char *d = dest;
    const unsigned char *s = src;

    while (n--) {
        *d++ = *s++;
    }

    return dest;
}
